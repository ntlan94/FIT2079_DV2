{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "The Renewable Ecosystem by State",
    "subtitle": "Trellis Scatter Plot: Solar (X) vs. Heat Pump (Y) vs. Battery (Size)",
    "fontSize": 18,
    "anchor": "start",
    "color": "#2c3e50"
  },
  "data": {
    "url": "data/sgu-solar-installations.csv",
    "format": {"type": "csv", "parse": {"Postcode": "string", "Total": "number"}}
  },
  "transform": [
    {"calculate": "toString(datum.Postcode)", "as": "PC"},
    {"calculate": "isValid(datum.Total) ? datum.Total : 0", "as": "Solar"},
    {
      "lookup": "PC",
      "from": {
        "data": {
          "url": "data/sgu-battery-installations.csv",
          "format": {"type": "csv", "parse": {"Postcode": "string", "Total": "number"}}
        },
        "key": "Postcode",
        "fields": ["Total"]
      },
      "as": ["Battery"]
    },
    {
      "lookup": "PC",
      "from": {
        "data": {
          "url": "data/swh-air-source-heat-pump-installations.csv",
          "format": {"type": "csv", "parse": {"Postcode": "string", "Total": "number"}}
        },
        "key": "Postcode",
        "fields": ["Total"]
      },
      "as": ["HP"]
    },
    {"calculate": "isValid(datum.Battery) ? datum.Battery : 0", "as": "Battery_Num"},
    {"calculate": "isValid(datum.HP) ? datum.HP : 0", "as": "HP_Num"},
    {"calculate": "length(datum.PC) == 3 ? '0' + datum.PC : datum.PC", "as": "PC_pad"},
    {"calculate": "datum.PC_pad[0] == '2' ? 'NSW' : datum.PC_pad[0] == '3' ? 'VIC' : datum.PC_pad[0] == '4' ? 'QLD' : datum.PC_pad[0] == '5' ? 'SA' : datum.PC_pad[0] == '6' ? 'WA' : datum.PC_pad[0] == '7' ? 'TAS' : 'Other'", "as": "State"},
    {"filter": "datum.State != 'Other' && datum.Solar > 0 && datum.HP_Num > 0"}
  ],
  "columns": 3,
  "facet": {
    "field": "State",
    "type": "nominal",
    "title": null,
    "sort": ["NSW", "VIC", "QLD", "WA", "SA", "TAS"]
  },
  "spec": {
    "width": 180,
    "height": 180,
    "mark": {"type": "circle", "opacity": 0.6, "stroke": "black", "strokeWidth": 0.5},
    "encoding": {
      "x": {
        "field": "Solar",
        "type": "quantitative",
        "title": "Solar Systems (Log Scale)",
        "scale": {"type": "log", "domain": [1, 5000]}
      },
      "y": {
        "field": "HP_Num",
        "type": "quantitative",
        "title": "Heat Pumps (Log Scale)",
        "scale": {"type": "log", "domain": [1, 5000]}
      },
      "size": {
        "field": "Battery_Num",
        "type": "quantitative",
        "title": "Batteries Installed",
        "scale": {"range": [10, 400]}
      },
      "color": {
        "field": "State",
        "type": "nominal",
        "scale": {"scheme": "category10"},
        "legend": null
      },
      "tooltip": [
        {"field": "PC", "type": "nominal", "title": "Postcode"},
        {"field": "Solar", "type": "quantitative", "format": ","},
        {"field": "HP_Num", "type": "quantitative", "title": "Heat Pumps", "format": ","},
        {"field": "Battery_Num", "type": "quantitative", "title": "Batteries", "format": ","}
      ]
    }
  },
  "config": {
    "view": {"stroke": "transparent"},
    "font": "sans-serif"
  }
}
