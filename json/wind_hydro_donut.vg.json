{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Beyond Solar: Small-Scale Wind vs. Hydro Adoption",
    "subtitle": "National distribution by State (Extracted dynamically from Postcodes)",
    "fontSize": 18,
    "anchor": "start",
    "color": "#2c3e50"
  },
  "hconcat": [
    {
      "width": 300,
      "height": 300,
      "title": {"text": "Wind Power Installations", "color": "#34495e"},
      "data": {"url": "https://ntlan94.github.io/FIT2079_DV2/data/sgu-wind-installations.csv", "format": {"type": "csv"}},
      "transform": [
        {"calculate": "toString(datum.Postcode)", "as": "PC"},
        {"calculate": "length(datum.PC) == 3 ? '0' + datum.PC : datum.PC", "as": "PC_pad"},
        {"calculate": "datum.PC_pad[0] == '0' ? 'NT' : datum.PC_pad[0] == '2' ? 'NSW/ACT' : datum.PC_pad[0] == '3' ? 'VIC' : datum.PC_pad[0] == '4' ? 'QLD' : datum.PC_pad[0] == '5' ? 'SA' : datum.PC_pad[0] == '6' ? 'WA' : datum.PC_pad[0] == '7' ? 'TAS' : 'Other'", "as": "State"},
        {"aggregate": [{"op": "sum", "field": "Total", "as": "Total_Qty"}], "groupby": ["State"]}
      ],
      "mark": {"type": "arc", "innerRadius": 70, "padAngle": 0.03, "cornerRadius": 4},
      "encoding": {
        "theta": {"field": "Total_Qty", "type": "quantitative"},
        "color": {
          "field": "State",
          "type": "nominal",
          "scale": {"scheme": "set2"},
          "legend": {"title": "State / Territory", "orient": "bottom", "columns": 4}
        },
        "tooltip": [
          {"field": "State", "type": "nominal"},
          {"field": "Total_Qty", "type": "quantitative", "title": "Wind Systems Installed", "format": ","}
        ]
      }
    },
    {
      "width": 300,
      "height": 300,
      "title": {"text": "Hydro Power Installations", "color": "#34495e"},
      "data": {"url": "https://ntlan94.github.io/FIT2079_DV2/data/sgu-hydro-installations.csv", "format": {"type": "csv"}},
      "transform": [
        {"calculate": "toString(datum.Postcode)", "as": "PC"},
        {"calculate": "length(datum.PC) == 3 ? '0' + datum.PC : datum.PC", "as": "PC_pad"},
        {"calculate": "datum.PC_pad[0] == '0' ? 'NT' : datum.PC_pad[0] == '2' ? 'NSW/ACT' : datum.PC_pad[0] == '3' ? 'VIC' : datum.PC_pad[0] == '4' ? 'QLD' : datum.PC_pad[0] == '5' ? 'SA' : datum.PC_pad[0] == '6' ? 'WA' : datum.PC_pad[0] == '7' ? 'TAS' : 'Other'", "as": "State"},
        {"aggregate": [{"op": "sum", "field": "Total", "as": "Total_Qty"}], "groupby": ["State"]}
      ],
      "mark": {"type": "arc", "innerRadius": 70, "padAngle": 0.03, "cornerRadius": 4},
      "encoding": {
        "theta": {"field": "Total_Qty", "type": "quantitative"},
        "color": {
          "field": "State",
          "type": "nominal",
          "scale": {"scheme": "set2"},
          "legend": null
        },
        "tooltip": [
          {"field": "State", "type": "nominal"},
          {"field": "Total_Qty", "type": "quantitative", "title": "Hydro Systems Installed", "format": ","}
        ]
      }
    }
  ],
  "config": {"view": {"stroke": "transparent"}, "font": "sans-serif"}
}
