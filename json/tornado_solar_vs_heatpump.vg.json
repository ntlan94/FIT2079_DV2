{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Electrification: Solar PV vs. Heat Pump Adoption",
    "subtitle": "Comparing total installations by State (Diverging Tornado Chart)",
    "fontSize": 18,
    "anchor": "start",
    "color": "#2c3e50"
  },
  "width": 650,
  "height": 350,
  "data": {
    "url": "https://ntlan94.github.io/FIT2079_DV2/data/sgu-solar-installations.csv",
    "format": {"type": "csv", "parse": {"Postcode": "string", "Total": "number"}}
  },
  "transform": [
    {
      "calculate": "toString(datum.Postcode)",
      "as": "PC"
    },
    {
      "lookup": "PC",
      "from": {
        "data": {
          "url": "https://ntlan94.github.io/FIT2079_DV2/data/swh-air-source-heat-pump-installations.csv",
          "format": {"type": "csv", "parse": {"Postcode": "string", "Total": "number"}}
        },
        "key": "Postcode",
        "fields": ["Total"]
      },
      "as": ["HP_Qty"]
    },
    {
      "calculate": "isValid(datum.HP_Qty) ? datum.HP_Qty : 0",
      "as": "HP_Qty_Num"
    },
    {
      "calculate": "isValid(datum.Total) ? datum.Total : 0",
      "as": "Solar_Qty_Num"
    },
    {
      "calculate": "length(datum.PC) == 3 ? '0' + datum.PC : datum.PC",
      "as": "PC_pad"
    },
    {
      "calculate": "datum.PC_pad[0] == '0' ? 'NT' : datum.PC_pad[0] == '2' ? 'NSW' : datum.PC_pad[0] == '3' ? 'VIC' : datum.PC_pad[0] == '4' ? 'QLD' : datum.PC_pad[0] == '5' ? 'SA' : datum.PC_pad[0] == '6' ? 'WA' : datum.PC_pad[0] == '7' ? 'TAS' : 'Other'",
      "as": "State"
    },
    {
      "filter": "datum.State != 'Other'"
    },
    {
      "aggregate": [
        {"op": "sum", "field": "Solar_Qty_Num", "as": "Sum_Solar"},
        {"op": "sum", "field": "HP_Qty_Num", "as": "Sum_HP"}
      ],
      "groupby": ["State"]
    },
    {
      "calculate": "-datum.Sum_Solar",
      "as": "Negative_Solar"
    }
  ],
  "layer": [
    {
      "mark": {"type": "bar", "color": "#f1c40f", "cornerRadiusTopLeft": 4, "cornerRadiusBottomLeft": 4},
      "encoding": {
        "x": {
          "field": "Negative_Solar",
          "type": "quantitative",
          "title": "← Solar PV Systems | Heat Pump Systems →",
          "axis": {
            "labelExpr": "abs(datum.value) / 1000 + 'k'",
            "tickCount": 6
          }
        },
        "y": {
          "field": "State",
          "type": "nominal",
          "axis": {
            "title": "",
            "labelFontWeight": "bold",
            "labelFontSize": 12
          },
          "sort": {"field": "Sum_Solar", "order": "descending"}
        },
        "tooltip": [
          {"field": "State", "type": "nominal"},
          {"field": "Sum_Solar", "type": "quantitative", "title": "Total Solar Installations", "format": ","}
        ]
      }
    },
    {
      "mark": {"type": "bar", "color": "#e74c3c", "cornerRadiusTopRight": 4, "cornerRadiusBottomRight": 4},
      "encoding": {
        "x": {
          "field": "Sum_HP",
          "type": "quantitative"
        },
        "y": {
          "field": "State",
          "type": "nominal",
          "sort": {"field": "Sum_Solar", "order": "descending"}
        },
        "tooltip": [
          {"field": "State", "type": "nominal"},
          {"field": "Sum_HP", "type": "quantitative", "title": "Total Heat Pump Installations", "format": ","}
        ]
      }
    }
  ],
  "config": {
    "view": {"stroke": "transparent"},
    "font": "sans-serif"
  }
}
