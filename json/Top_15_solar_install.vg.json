{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Top 15 Australian Postcodes: Installations vs. Capacity",
    "subtitle": "Dual-Axis Lollipop Chart highlighting installation counts and total capacity (kW)",
    "fontSize": 18,
    "anchor": "start",
    "color": "#2c3e50"
  },
  "width": 800,
  "height": 500,
  "data": {
    "url": "data/sgu-solar-installations.csv",
    "format": {"type": "csv", "parse": {"Postcode": "string", "Total": "number", "Capacity": "number"}}
  },
  "transform": [
    {"filter": "datum.Total > 0"},
    {
      "window": [{"op": "rank", "as": "rank"}],
      "sort": [{"field": "Total", "order": "descending"}]
    },
    {"filter": "datum.rank <= 15"}
  ],
  "encoding": {
    "y": {
      "field": "Postcode",
      "type": "nominal",
      "sort": {"field": "Total", "order": "descending"},
      "title": "Postcode",
      "axis": {
        "grid": true,
        "gridDash": [4, 4],
        "gridColor": "#e0e0e0"
      }
    }
  },
  "layer": [
    {
      "description": "Group 1: Orange Stick and Dot for Installations (Lower Axis)",
      "layer": [
        {
          "mark": {"type": "rule", "color": "#f39c12", "strokeWidth": 3, "opacity": 0.6},
          "encoding": {
            "x": {"datum": 950},
            "x2": {"field": "Total"}
          }
        },
        {
          "mark": {"type": "circle", "size": 300, "color": "#f39c12", "opacity": 1},
          "encoding": {
            "x": {
              "field": "Total",
              "type": "quantitative",
              "title": "Total Installations (Orange)",
              "scale": {"domainMin": 950},
              "axis": {"titleColor": "#f39c12", "labelColor": "#f39c12", "orient": "bottom"}
            },
            "tooltip": [
              {"field": "Postcode", "type": "nominal"},
              {"field": "Total", "type": "quantitative", "title": "Installations", "format": ","}
            ]
          }
        }
      ]
    },
    {
      "description": "Group 2: Blue Dot for Capacity (Upper Axis)",
      "mark": {"type": "circle", "size": 300, "color": "#2980b9", "opacity": 1},
      "encoding": {
        "x": {
          "field": "Capacity",
          "type": "quantitative",
          "title": "Total Capacity in kW (Blue)",
          "axis": {"titleColor": "#2980b9", "labelColor": "#2980b9", "orient": "top"}
        },
        "tooltip": [
          {"field": "Postcode", "type": "nominal"},
          {"field": "Capacity", "type": "quantitative", "title": "Capacity (kW)", "format": ","}
        ]
      }
    }
  ],
  "resolve": {
    "scale": {"x": "independent"}
  },
  "config": {
    "view": {"stroke": "transparent"},
    "font": "sans-serif"
  }
}
