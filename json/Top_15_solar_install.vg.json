{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Top 15 Australian Postcodes by Solar Installations",
    "fontSize": 18,
    "anchor": "start",
    "color": "#2c3e50"
  },
  "width": 800,
  "height": 500,
  "data": {
    "url": "data/sgu-solar-installations.csv",
    "format": {"type": "csv", "parse": {"Postcode": "string", "Total": "number"}}
  },
  "transform": [
    {"filter": "datum.Total > 0"},
    {
      "window": [{"op": "rank", "as": "rank"}],
      "sort": [{"field": "Total", "order": "descending"}]
    },
    {"filter": "datum.rank <= 15"}
  ],
  "mark": {
    "type": "bar",
    "color": "#f39c12",
    "cornerRadiusEnd": 4
  },
  "encoding": {
    "y": {
      "field": "Postcode",
      "type": "nominal",
      "sort": {"field": "Total", "order": "descending"},
      "title": "Postcode",
      "axis": {"labelFontSize": 12, "titleFontSize": 14}
    },
    "x": {
      "field": "Total",
      "type": "quantitative",
      "title": "Total Installations",
      "axis": {"labelFontSize": 12, "titleFontSize": 14}
    },
    "tooltip": [
      {"field": "Postcode", "type": "nominal"},
      {"field": "Total", "type": "quantitative", "format": ",", "title": "Total Installations"}
    ]
  },
  "config": {
    "view": {"stroke": "transparent"},
    "font": "sans-serif"
  }
}
