{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "The Shift in Power: Evolution of the Residential Battery Market Shared by State",
    "subtitle": "100% Stacked Area Chart showing the shifting dominance from SA to NSW/VIC (2014-2025)",
    "fontSize": 18,
    "subtitleFontSize": 13,
    "anchor": "start",
    "color": "#2c3e50",
    "subtitleColor": "#7f8c8d"
  },
  "data": {
    "url": "data/historical-battery-installation.csv",
    "format": { "type": "csv" }
  },
  "transform": [
    {
      "fold": ["ACT", "NSW", "NT", "QLD", "SA", "TAS", "VIC", "WA"],
      "as": ["State", "RawValue"]
    },
    {
      "calculate": "toNumber(replace(datum.RawValue, ',', ''))",
      "as": "Installations"
    },
    {
      "calculate": "datetime(toNumber(datum['Installation year']), 0, 1)",
      "as": "Year"
    }
  ],
  "vconcat": [
    {
      "description": "TOP CHART: Focus View",
      "width": 720,
      "height": 300,
      "mark": { "type": "area", "opacity": 0.9 },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "temporal",
          "scale": { "domain": { "param": "brush" } },
          "axis": { "title": "", "grid": false, "labelFontSize": 12, "format": "%Y" }
        },
        "y": {
          "field": "Installations",
          "type": "quantitative",
          "stack": "normalize",
          "axis": {
            "format": "%",
            "title": "Market Share",
            "titleFontSize": 13,
            "labelFontSize": 12
          }
        },
        "color": {
          "field": "State",
          "type": "nominal",
          "scale": { "scheme": "tableau10" },
          "legend": { "title": "State", "orient": "right" }
        },
        "tooltip": [
          { "field": "Year", "type": "temporal", "title": "Year", "format": "%Y" },
          { "field": "State", "type": "nominal" },
          { "field": "Installations", "type": "quantitative", "title": "Installations", "format": "," }
        ]
      }
    },
    {
      "description": "BOTTOM CHART: Context / brush selector",
      "width": 720,
      "height": 60,
      "mark": { "type": "area", "opacity": 0.4 },
      "params": [
        {
          "name": "brush",
          "select": { "type": "interval", "encodings": ["x"] }
        }
      ],
      "encoding": {
        "x": {
          "field": "Year",
          "type": "temporal",
          "axis": {
            "title": "Timeline Overview (Click and drag to select range)",
            "titleFontSize": 12,
            "grid": false,
            "format": "%Y"
          }
        },
        "y": {
          "field": "Installations",
          "type": "quantitative",
          "stack": "normalize",
          "axis": { "tickCount": 3, "grid": false, "labels": false, "title": "" }
        },
        "color": {
          "field": "State",
          "type": "nominal",
          "legend": null
        }
      }
    }
  ],
  "config": {
    "view": { "stroke": "transparent" },
    "font": "sans-serif"
  }
}
