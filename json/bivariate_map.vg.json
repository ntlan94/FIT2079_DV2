{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Solar vs. Battery Convergence Map",
    "subtitle": "Bivariate Choropleth highlighting regions with high solar but low battery adoption",
    "fontSize": 18,
    "anchor": "start",
    "color": "#2c3e50"
  },
  "width": 800,
  "height": 600,
  "params": [
    {
      "name": "state_focus", "value": "National",
      "bind": {
        "input": "select",
        "options": ["National", "VIC", "NSW", "QLD", "WA", "SA", "TAS", "NT"],
        "labels": ["National Focus", "Victoria", "New South Wales", "Queensland", "Western Australia", "South Australia", "Tasmania", "Northern Territory"],
        "name": "Region Focus: "
      }
    },
    {
      "name": "zoom_level", "value": 800,
      "bind": {"input": "range", "min": 400, "max": 3000, "step": 50, "name": "Manual Zoom: "}
    }
  ],
  "projection": {
    "type": "equirectangular",
    "center": {
      "expr": "state_focus == 'National' ? [133, -28] : state_focus == 'VIC' ? [145, -37.2] : state_focus == 'NSW' ? [147, -32.8] : state_focus == 'QLD' ? [144.5, -22.5] : state_focus == 'WA' ? [122, -26.0] : state_focus == 'SA' ? [135, -30.0] : state_focus == 'TAS' ? [146.5, -42.0] : [133.5, -19.5]"
    },
    "scale": {
      "expr": "zoom_level * (state_focus == 'National' ? 1 : state_focus == 'VIC' ? 3.5 : state_focus == 'NSW' ? 3.0 : state_focus == 'QLD' ? 2.3 : state_focus == 'WA' ? 2.0 : state_focus == 'SA' ? 2.5 : state_focus == 'TAS' ? 5.5 : 2.8)"
    }
  },
  "data": {
    "url": "data/Australia_poa.topojson",
    "format": {"type": "topojson", "feature": "POA_2016_AUST"}
  },
  "transform": [
    {"calculate": "toString(datum.properties.POA_CODE16)", "as": "Postcode"},
    {
      "lookup": "Postcode",
      "from": {
        "data": {"url": "data/sgu-solar-installations.csv", "format": {"type": "csv", "parse": {"Postcode": "string", "Total": "number"}}},
        "key": "Postcode",
        "fields": ["Total"]
      },
      "as": ["Solar_Qty"]
    },
    {
      "lookup": "Postcode",
      "from": {
        "data": {"url": "data/sgu-battery-installations.csv", "format": {"type": "csv", "parse": {"Postcode": "string", "Total": "number"}}},
        "key": "Postcode",
        "fields": ["Total"]
      },
      "as": ["Battery_Qty"]
    },
    {"calculate": "isValid(datum.Solar_Qty) ? datum.Solar_Qty : 0", "as": "S_Qty"},
    {"calculate": "isValid(datum.Battery_Qty) ? datum.Battery_Qty : 0", "as": "B_Qty"},
    
    {"calculate": "datum.S_Qty < 500 ? '1' : datum.S_Qty < 2000 ? '2' : '3'", "as": "S_Class"},
    {"calculate": "datum.B_Qty < 10 ? '1' : datum.B_Qty < 50 ? '2' : '3'", "as": "B_Class"},
    {"calculate": "datum.S_Class + '-' + datum.B_Class", "as": "Bivariate_Class"}
  ],
  "mark": {"type": "geoshape", "stroke": "#ffffff", "strokeWidth": 0.1},
  "encoding": {
    "color": {
      "field": "Bivariate_Class",
      "type": "nominal",
      "scale": {
        "domain": ["1-1", "1-2", "1-3", "2-1", "2-2", "2-3", "3-1", "3-2", "3-3"],
        "range": ["#e8e8e8", "#ace4e4", "#5ac8c8", "#dfb0d6", "#a5add3", "#5698b9", "#be64ac", "#8c62aa", "#3b4994"]
      },
      "legend": null
    },
    "tooltip": [
      {"field": "Postcode", "type": "nominal"},
      {"field": "S_Qty", "type": "quantitative", "title": "Solar Installations", "format": ","},
      {"field": "B_Qty", "type": "quantitative", "title": "Battery Installations", "format": ","}
    ]
  },
  "config": {"view": {"stroke": null}, "font": "sans-serif"}
}
